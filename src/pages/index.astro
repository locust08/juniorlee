const loanFormScript = `<script>
document.addEventListener("DOMContentLoaded", function () {
  var panel = document.getElementById("loan-application-form");
  if (!panel) return;
  var loanInput = panel.querySelector('input[name="loan_type"]');
  var nameInput = panel.querySelector('input[name="name"]');
  function openLoanForm(loanType) {
    panel.classList.add("is-visible");
    panel.setAttribute("aria-hidden", "false");
    if (loanInput) loanInput.value = loanType && loanType !== "general" ? loanType : "";
    panel.scrollIntoView({ block: "start", behavior: "smooth" });
    window.setTimeout(function () { if (nameInput) nameInput.focus(); }, 350);
  }
  document.querySelectorAll("[data-loan-form-trigger]").forEach(function (button) {
    button.addEventListener("click", function (event) {
      event.preventDefault();
      openLoanForm(button.getAttribute("data-loan-form-trigger"));
    });
  });
  if (window.location.hash === "#loan-application-form") {
    openLoanForm("general");
  }
  var closeButton = panel.querySelector(".loan-form-close");
  if (closeButton) {
    closeButton.addEventListener("click", function () {
      panel.classList.remove("is-visible");
      panel.setAttribute("aria-hidden", "true");
    });
  }
  document.querySelectorAll(".document-toggle").forEach(function (toggle) {
    var list = toggle.nextElementSibling;
    var icon = toggle.querySelector(".document-toggle-icon");
    toggle.addEventListener("click", function () {
      if (!list) return;
      var isOpen = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!isOpen));
      list.hidden = isOpen;
      if (icon) icon.textContent = isOpen ? "+" : "-";
    });
  });
});
</script>`;

